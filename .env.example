# ─── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# PostgreSQL (Neon in prod, local docker postgres for compose).
# Get yours at https://neon.tech — must include ?sslmode=require for Neon.
DATABASE_URL="postgresql://user:password@host:5432/release_checklist?sslmode=require"

# Redis cache (optional). App degrades gracefully to no-cache if unreachable.
# Upstash in prod (rediss://...) or your local instance.
REDIS_URL="redis://localhost:6379"

# Cache TTL for the releases list, in seconds.
CACHE_TTL_SECONDS=60

# Comma-separated list of allowed browser origins (CORS).
# Leave empty to allow all (dev only). In prod set to the web app URL.
WEB_ORIGIN="http://localhost:5173"

# ─── Web (Vite, build-time) ──────────────────────────────────────────────────
# Base URL of the API. Leave empty for same-origin (docker/nginx proxy).
# On Render set to the API service URL, e.g. https://release-checklist-api.onrender.com
VITE_API_URL=""
